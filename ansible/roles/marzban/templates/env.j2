# Managed by Ansible (mode 0600). Admin creds read from the operator's
# environment (loaded from .env by vpnctl) — never passed via --extra-vars,
# never logged (FR-9 / NFR-9).
MARZBAN_VERSION={{ marzban_version }}
MARZBAN_PORT={{ marzban_port }}
SUDO_USERNAME={{ lookup('env', 'MARZBAN_ADMIN_USER') }}
SUDO_PASSWORD={{ lookup('env', 'MARZBAN_ADMIN_PASS') }}
{% if marzban_panel_domain | length > 0 %}
XRAY_SUBSCRIPTION_URL_PREFIX=https://{{ marzban_panel_domain }}
{% endif %}

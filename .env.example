# =============================================================================
# vpn-selfhost — конфигурация оператора (§10 ТЗ)
# Скопировать в .env и заполнить. НИКОГДА не коммить .env (FR-9.1). Права 600 (FR-9.3).
# =============================================================================

# --- Провайдер VPS ---------------------------------------------------------
# Используемый адаптер. Поддерживаются: upcloud | scaleway  (см. infra/providers/)
VPS_PROVIDER=upcloud
VPS_API_TOKEN=
# UpCloud использует логин/пароль вместо единого токена; тогда задай эти:
VPS_API_USER=
VPS_API_PASSWORD=
VPS_REGION=fi-hel1            # напр. fi-hel1 (Хельсинки), nl-ams1, de-fra1, se-sto1
VPS_PLAN=1xCPU-2GB            # id тарифа провайдера (см. доки провайдера)
VPS_IMAGE=Ubuntu Server 24.04 LTS
SSH_PUBLIC_KEY_PATH=~/.ssh/id_ed25519.pub
SSH_PRIVATE_KEY_PATH=~/.ssh/id_ed25519
SSH_PORT=22                  # меняется на сервере при харденинге, если задан SSH_HARDENED_PORT
SSH_HARDENED_PORT=22         # напр. 2222, чтобы увести SSH с 22 (FR-2.2)

# --- Marzban ---------------------------------------------------------------
MARZBAN_ADMIN_USER=
MARZBAN_ADMIN_PASS=
MARZBAN_PANEL_DOMAIN=        # опц.; пусто = доступ только через SSH-туннель (FR-3.3 / О-3)
MARZBAN_PORT=8000            # bind только на 127.0.0.1, если не задан домен
MARZBAN_VERSION=v0.8.4       # запиненный тег образа (FR-3.1); последний стабильный на 2026-07
XRAY_VERSION=26.3.27         # запиненная версия Xray-core; последняя стабильная на 2026-07

# --- VLESS / Reality -------------------------------------------------------
REALITY_SNI=                 # маскировочный домен; проверяется `vpnctl sni check` (FR-4.3)
REALITY_SHORT_ID=            # опц.; генерируется, если пусто (FR-4.1)
REALITY_PRIVATE_KEY=         # опц.; генерируется `vpnctl reality keygen`, если пусто
REALITY_PUBLIC_KEY=          # выводится из приватного ключа
REALITY_FINGERPRINT=chrome   # О-2

# --- AmneziaWG (резерв) ----------------------------------------------------
AWG_PORT=51820
AWG_DEPLOY_MODE=same-host    # same-host | separate-host (FR-5.3)
# Только для AWG_DEPLOY_MODE=separate-host — параметры второго VPS:
AWG_SEPARATE_HOST=           # IP или хост выделенного VPS под AWG
AWG_SEPARATE_SSH_PORT=22

# --- Мониторинг / алерты ---------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
CHECKHOST_ENABLED=true
# Слаги RU-нод check-host.net через запятую (пусто = авто-выбор RU-нод)
CHECKHOST_RU_NODES=
MONITOR_FREEZE_THRESHOLD_KB=18   # FR-7.2 порог симптома «заморозки» (~15–20 КБ)

# --- Бэкапы ----------------------------------------------------------------
BACKUP_DIR=./backups
BACKUP_REMOTE=              # опц. внешнее хранилище (rclone remote)
BACKUP_PASSPHRASE=          # симметричная фраза для шифрования секретов в бэкапах (FR-8.1)

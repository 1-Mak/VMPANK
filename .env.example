# =============================================================================
# vpn-selfhost — operator configuration (§10 ТЗ)
# Copy to .env and fill in. NEVER commit .env (FR-9.1). File mode 600 (FR-9.3).
# =============================================================================

# --- Провайдер VPS ---------------------------------------------------------
# Adapter to use. Supported: upcloud | scaleway  (see infra/providers/)
VPS_PROVIDER=upcloud
VPS_API_TOKEN=
# UpCloud uses user/pass instead of a single token; if so set these:
VPS_API_USER=
VPS_API_PASSWORD=
VPS_REGION=fi-hel1            # e.g. fi-hel1 (Helsinki), nl-ams1, de-fra1, se-sto1
VPS_PLAN=1xCPU-2GB            # provider plan id (see provider docs)
VPS_IMAGE=Ubuntu Server 24.04 LTS
SSH_PUBLIC_KEY_PATH=~/.ssh/id_ed25519.pub
SSH_PRIVATE_KEY_PATH=~/.ssh/id_ed25519
SSH_PORT=22                  # changed on the server during hardening if you set SSH_HARDENED_PORT
SSH_HARDENED_PORT=22         # set e.g. 2222 to move SSH off 22 (FR-2.2)

# --- Marzban ---------------------------------------------------------------
MARZBAN_ADMIN_USER=
MARZBAN_ADMIN_PASS=
MARZBAN_PANEL_DOMAIN=        # optional; empty = SSH-tunnel-only access (FR-3.3 / О-3)
MARZBAN_PORT=8000            # bound to 127.0.0.1 only unless a domain is set
MARZBAN_VERSION=v0.8.4       # pinned image tag (FR-3.1); latest stable as of 2026-07
XRAY_VERSION=26.3.27         # pinned Xray-core version; latest stable as of 2026-07

# --- VLESS / Reality -------------------------------------------------------
REALITY_SNI=                 # masquerade domain; validated by `vpnctl sni check` (FR-4.3)
REALITY_SHORT_ID=            # optional; generated if empty (FR-4.1)
REALITY_PRIVATE_KEY=         # optional; generated by `vpnctl reality keygen` if empty
REALITY_PUBLIC_KEY=          # derived from private key
REALITY_FINGERPRINT=chrome   # О-2

# --- AmneziaWG (резерв) ----------------------------------------------------
AWG_PORT=51820
AWG_DEPLOY_MODE=same-host    # same-host | separate-host (FR-5.3)
# Only for AWG_DEPLOY_MODE=separate-host — parameters of the 2nd VPS:
AWG_SEPARATE_HOST=           # IP or hostname of the dedicated AWG VPS
AWG_SEPARATE_SSH_PORT=22

# --- Мониторинг / алерты ---------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
CHECKHOST_ENABLED=true
# Comma-separated check-host.net RU node slugs (empty = auto-pick RU nodes)
CHECKHOST_RU_NODES=
MONITOR_FREEZE_THRESHOLD_KB=18   # FR-7.2 "заморозка" symptom threshold (~15-20 KB)

# --- Бэкапы ----------------------------------------------------------------
BACKUP_DIR=./backups
BACKUP_REMOTE=              # optional rclone remote, e.g. myremote:vpn-backups
BACKUP_PASSPHRASE=          # symmetric passphrase to encrypt secrets in backups (FR-8.1)

# Секреты — никогда не коммитить (FR-9.1)
.env
*.env
!.env.example
secrets/
*.vault
*.key
*.pem
id_ed25519*
id_rsa*

# Сгенерированные конфиги / локальное состояние (содержат ключи, IP)
.build/
.state/

# Бэкапы (FR-8, gitignored-артефакты)
backups/
*.tar.gz
*.tar.gz.age
*.tar.gz.gpg

# Стейт Terraform (содержит секреты/IP)
infra/**/.terraform/
infra/**/*.tfstate
infra/**/*.tfstate.*
infra/**/*.tfvars
!infra/**/*.tfvars.example
crash.log

# Ansible
ansible/*.retry
ansible/inventory/hosts.generated*

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
*.egg-info/
dist/
build/
.coverage
htmlcov/

# ОС / редактор
.DS_Store
Thumbs.db
.idea/
.vscode/

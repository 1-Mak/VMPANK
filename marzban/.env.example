# Env контейнера Marzban (рендерится на сервер Ansible'ом из .env оператора).
# Запиненные версии (FR-3.1). Никогда не коммить сюда реальные секреты.
MARZBAN_VERSION=v0.8.4
MARZBAN_PORT=8000

# Bootstrap админа панели (совпадает с MARZBAN_ADMIN_USER / MARZBAN_ADMIN_PASS).
SUDO_USERNAME=
SUDO_PASSWORD=

# Настройки subscription — держи хост URL стабильным (домен), чтобы ротация IP
# не заставляла клиентов переимпортировать (см. rotate.py / FR-8.3).
XRAY_SUBSCRIPTION_URL_PREFIX=

# Marzban container env (rendered onto the server by Ansible from operator .env).
# Pinned versions (FR-3.1). Never commit real secrets here.
MARZBAN_VERSION=v0.8.4
MARZBAN_PORT=8000

# Panel admin bootstrap (matches MARZBAN_ADMIN_USER / MARZBAN_ADMIN_PASS).
SUDO_USERNAME=
SUDO_PASSWORD=

# Subscription settings — keep the URL host stable (domain) so IP rotation does
# not force clients to reimport (see rotate.py / FR-8.3).
XRAY_SUBSCRIPTION_URL_PREFIX=
